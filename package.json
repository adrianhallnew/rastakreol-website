{
  "name": "rasta-kreol",
  "version": "1.0.0",
  "description": "Rasta Kreol — Seychelles-rooted merch store",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "bs": "pnpm build && pnpm start",
    "test": "echo \"No tests yet\"",
    "prepare": "git rev-parse --git-dir 2>/dev/null && lefthook install || true"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/plugin-seo": "^3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/storage-s3": "^3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@tailwindcss/postcss": "^4.3.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "googleapis": "^173.0.0",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.85.2",
    "postcss": "^8.5.15",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-email": "^6.6.5",
    "resend": "^6.16.0",
    "sharp": "0.34.2",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "28.0.0",
    "lefthook": "^2.1.9",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^22",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "lefthook"
    ]
  }
}
