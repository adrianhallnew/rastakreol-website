# ─────────────────────────────────────────
# Database (Supabase PostgreSQL)
# Use pooler/transaction mode (port 6543) for Vercel deployment
# ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────
# Payload CMS
# Generate: openssl rand -base64 32
# ─────────────────────────────────────────
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─────────────────────────────────────────
# Supabase Storage (S3-compatible)
# Supabase dashboard → Settings → API
# ─────────────────────────────────────────
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
STORAGE_BUCKET=product-media
# S3-compatible keys — Supabase → Storage → S3 Access Keys → New access key
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=

# ─────────────────────────────────────────
# Resend (transactional email)
# resend.com → API Keys
# ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────
# Google OAuth (customer login)
# console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: [SERVER_URL]/api/auth/google/callback
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────
# MCB Seychelles Payment
# Values from MCB API docs
# ─────────────────────────────────────────
MCB_API_KEY=
MCB_API_URL=
MCB_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# Vercel Cron (cart cleanup auth)
# Generate: openssl rand -base64 32
# ─────────────────────────────────────────
CRON_SECRET=
